# Supabase プロジェクトの設定 (ダッシュボード > Settings > API からコピー)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ログインを許可する Google Workspace ドメイン (学校ドメイン)
# 例: example-school.ac.jp  → @example-school.ac.jp のアカウントのみ許可
# 空にするとドメイン制限なし (ローカル開発用)
NEXT_PUBLIC_ALLOWED_GOOGLE_DOMAIN=example-school.ac.jp
