# ローカル開発用 SQLite (リポジトリにはコミットされない)
DATABASE_URL="file:./dev.db"

# iOSショートカット等から POST /api/items を叩くための固定キー。
# `openssl rand -hex 32` などで生成した長いランダム文字列を設定する。
SCRAPBOOK_API_KEY="change-me"

# --- 本番 (Vercel + Turso) に載せ替える場合のみ設定 ---
# 設定すると lib/db.ts が SQLite ファイルの代わりに Turso へ接続する
# TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
# TURSO_AUTH_TOKEN="..."
